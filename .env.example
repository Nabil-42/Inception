# Inception — Environment Variables
# Copy this file to .env and fill in the values before running make

# Domain name (use localhost or your 42 login + .42.fr)
DOMAIN_NAME=login.42.fr

# MariaDB
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=wordpress
MYSQL_USER=wp_user
MYSQL_PASSWORD=change_me_wp

# WordPress admin account
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=change_me_admin
WP_ADMIN_EMAIL=admin@example.com

# WordPress regular user
WP_USER=editor
WP_USER_PASSWORD=change_me_editor
WP_USER_EMAIL=editor@example.com